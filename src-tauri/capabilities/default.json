{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Game Manager ana pencere izinleri — SQL, Shell, Filesystem, Opener",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "opener:default",
    "shell:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "C:\\Program Files (x86)\\Steam\\**" },
        { "path": "C:\\Program Files\\Steam\\**" },
        { "path": "C:\\Program Files\\Epic Games\\**" },
        { "path": "C:\\ProgramData\\Epic\\**" },
        { "path": "D:\\Steam\\**" },
        { "path": "D:\\SteamLibrary\\**" },
        { "path": "E:\\SteamLibrary\\**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "**" }
      ]
    }
  ]
}
